---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { dateRange } from "@lib/utils";
import { SITE, HOME, SOCIALS } from "@consts";
import profileImage from "../assets/profile.jpeg";

const projects = (await getCollection("projects"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const allwork = (await getCollection("work"))
  .sort(
    (a, b) =>
      new Date(b.data.dateStart).valueOf() -
      new Date(a.data.dateStart).valueOf(),
  )
  .slice(0, SITE.NUM_WORKS_ON_HOMEPAGE);

const work = await Promise.all(
  allwork.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  }),
);
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="animate mt-4 flex justify-center show">
      <Image
        src={profileImage}
        alt="Portrait of Matthias"
        width={384}
        height={384}
        quality={95}
        format="webp"
        class="h-48 w-48 rounded-full object-cover ring-1 ring-black/10 dark:ring-white/20"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </div>
    <h4 class="animate font-semibold text-black dark:text-white">
      Hi, I'm Leon <span class="text-xl">👋🏻</span>
    </h4>
    <div class="space-y-16">
      <section>
        <article class="space-y-4">
          <p class="animate text-justify">
            I am a Software Engineer with a unique background that blends the precision of Biochemistry with the logic of Computer Science. My journey began in the lab, where I published research on metabolic pathways and protein structures, but I eventually found my true calling in building the digital systems that power modern innovation. Today, I leverage that scientific rigor to engineer robust backend solutions, having most recently worked on complex industrial frameworks at Dematic and explored the intersection of AI and education for my Engineering thesis.
          </p>
          <p class="animate text-justify">
            Beyond the IDE, I am a firm believer that the best problem-solving happens when you step away from the screen. Whether I’m navigating the complex mechanics of a strategy board game or experimenting with new flavors in the kitchen, I bring the same curiosity and attention to detail to my hobbies as I do to my code. I thrive at the crossroads of technical challenge and creative execution, and I’m always looking for the next interesting project to build.
          </p>
        </article>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Work Experience
          </h5>
          <Link href="/cv"> See full cv </Link>
        </div>
        <ul class="flex flex-col space-y-4">
          {
            work.map((entry) => (
              <li>
                <div class="text-sm opacity-75">
                  {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                </div>
                <div class="font-semibold text-black dark:text-white">
                  {entry.data.company}
                </div>
                <div class="text-sm opacity-75">{entry.data.role}</div>
                <article>
                  <entry.Content />
                </article>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Recent projects
          </h5>
          <Link href="/projects"> See all projects </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {
            projects.map((project) => (
              <li>
                <ArrowCard entry={project} />
              </li>
            ))
          }
        </ul>
      </section>

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">Let's Connect</h5>
        <article>
          <p>
            If you want to get in touch with me about something or just to say
            hi, reach out on social media.
          </p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {
            SOCIALS.map((SOCIAL) => (
              <li class="flex gap-x-2 text-nowrap">
                <Link
                  href={SOCIAL.HREF}
                  external
                  aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}
                >
                  {SOCIAL.NAME}
                </Link>
                {"/"}
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
