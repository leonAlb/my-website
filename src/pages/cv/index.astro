---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { dateRange } from "@lib/utils";
import { WORK } from "@consts";

const collection = (await getCollection("work")).sort(
  (a, b) =>
    new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf(),
);

const work = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  }),
);

const academicsCollection = (await getCollection("academics")).sort(
  (a, b) =>
    new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf(),
);

const academics = await Promise.all(
  academicsCollection.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  }),
);

const publicationsCollection = (await getCollection("publications")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const publications = await Promise.all(
  publicationsCollection.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  }),
);
---

<PageLayout title={WORK.TITLE} description={WORK.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div class="animate font-bold text-black dark:text-white">CV</div>

      <section class="space-y-6">
        <h5 class="animate font-semibold text-black dark:text-white">
          Work Experience
        </h5>
        <ul class="flex flex-col space-y-4">
          {
            work.map((entry) => (
              <li class="animate">
                <div class="text-sm opacity-75">
                  {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                </div>
                <div class="font-semibold text-black dark:text-white">
                  {entry.data.company}
                </div>
                <div class="text-sm opacity-75">{entry.data.role}</div>
                <article>
                  <entry.Content />
                </article>
              </li>
            ))
          }
        </ul>
      </section>

      <hr class="border-black/15 dark:border-white/20" />

      <section class="space-y-6">
        <h5 class="animate font-semibold text-black dark:text-white">
          Academics
        </h5>
        <ul class="flex flex-col space-y-4">
          {
            academics.map((entry) => (
              <li class="animate">
                <div class="text-sm opacity-75">
                  {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                </div>
                <div class="font-semibold text-black dark:text-white">
                  {entry.data.program}
                </div>
                <div class="text-sm opacity-75">
                  {entry.data.institution} (Grade: {entry.data.grade})
                </div>
                <div class="text-sm opacity-75">
                  Thesis: {entry.data.thesis}
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <hr class="border-black/15 dark:border-white/20" />

      <section class="space-y-6">
        <h5 class="animate font-semibold text-black dark:text-white">
          Publications
        </h5>
        <ul class="flex flex-col space-y-4">
          {
            publications.map((entry) => (
              <li class="animate">
                <div class="text-sm opacity-75">
                  <FormattedDate date={entry.data.date} />
                </div>
                <div class="font-semibold text-black dark:text-white">
                  {entry.data.title}
                </div>
                {entry.data.venue && (
                  <div class="text-sm opacity-75">{entry.data.venue}</div>
                )}
                <div class="text-sm opacity-75">
                  Authors: {entry.data.authors}
                </div>
                <article>
                  <entry.Content />
                </article>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
