---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
---

<PageLayout
  title="Impressum"
  description="Impressum / Legal Notice."
>
  <Container>
    <div class="space-y-8">
      <h1 class="animate text-2xl font-extrabold text-black dark:text-white">
        Impressum
      </h1>

      <section class="space-y-4">
        <div class="space-y-1 text-sm opacity-75">
          <div><strong>Name:</strong> Leon Albert</div>
          <div><strong>Adresse:</strong> Am Exerzierplatz 3a, 97072 Würzburg</div>
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="animate font-semibold text-black dark:text-white">
          Kontakt
        </h2>
        <div class="space-y-1 text-sm opacity-75">
          <div><strong>E-Mail:</strong> leon.albert@t-online.de</div>
          <div><strong>Telefon:</strong> +491514 1277597</div>
        </div>
      </section>
    </div>
  </Container>
</PageLayout>
